  },
  "specs": {
    "tiny": {
      "root": "card-1",
      "elements": {
        "card-1": { "type": "Card", "props": { "title": "Login" }, "children": ["email-input", "btn-1"] },
        "email-input": { "type": "Input", "props": { "label": "Email", "placeholder": "you@example.com", "type": "email" }, "children": [] },
        "btn-1": { "type": "Button", "props": { "label": "Sign In", "variant": "primary" }, "children": [] }
      }
    },
    "small": {
      "root": "main",
      "elements": {
        "main": { "type": "Stack", "props": { "direction": "vertical", "gap": 4 }, "children": ["header", "metrics-grid", "table-card"] },
        "header": { "type": "Heading", "props": { "level": 1, "text": "Dashboard" }, "children": [] },
        "metrics-grid": { "type": "Grid", "props": { "columns": 3, "gap": 4 }, "children": ["metric-1", "metric-2", "metric-3"] },
        "metric-1": { "type": "Metric", "props": { "label": "Revenue", "value": "$42,000", "trend": "up" }, "children": [] },
        "metric-2": { "type": "Metric", "props": { "label": "Users", "value": "1,234", "trend": "up" }, "children": [] },
        "metric-3": { "type": "Metric", "props": { "label": "Orders", "value": "89", "trend": "down" }, "children": [] },
        "table-card": { "type": "Card", "props": { "title": "Recent Orders" }, "children": ["orders-table"] },
        "orders-table": { "type": "Table", "props": { "headers": ["ID", "Customer", "Amount", "Status"], "rows": [["#001", "Alice", "$150", "Shipped"], ["#002", "Bob", "$89", "Pending"]] }, "children": [] }
      }
    },
    "3d_product": {
      "root": "scene",
      "elements": {
        "scene": { "type": "Group", "props": { "position": [0,0,0] }, "children": ["camera", "controls", "env", "light-amb", "light-key", "floor", "sphere-float", "shadows", "effects"] },
        "camera": { "type": "PerspectiveCamera", "props": { "position": [5,3,5], "fov": 45, "makeDefault": true }, "children": [] },
        "controls": { "type": "OrbitControls", "props": { "enableDamping": true, "autoRotate": true, "autoRotateSpeed": 1.0 }, "children": [] },
        "env": { "type": "Environment", "props": { "preset": "studio", "background": false }, "children": [] },
        "light-amb": { "type": "AmbientLight", "props": { "intensity": 0.4 }, "children": [] },
        "light-key": { "type": "DirectionalLight", "props": { "position": [5,8,5], "intensity": 1.2, "castShadow": true }, "children": [] },
        "floor": { "type": "ReflectorPlane", "props": { "mirror": 0.5, "blur": [300,100], "resolution": 1024, "mixStrength": 0.8, "position": [0,-0.01,0], "rotation": [-1.5708,0,0] }, "children": [] },
        "sphere-float": { "type": "Float", "props": { "speed": 1.5, "rotationIntensity": 0.4, "floatIntensity": 0.6 }, "children": ["sphere"] },
        "sphere": { "type": "Sphere", "props": { "radius": 1, "position": [0,1.5,0], "material": { "color": "#4488ff", "metalness": 0.9, "roughness": 0.1 }, "castShadow": true }, "children": [] },
        "shadows": { "type": "ContactShadows", "props": { "opacity": 0.6, "blur": 2, "position": [0,-0.01,0] }, "children": [] },
        "effects": { "type": "EffectComposer", "props": { "enabled": true }, "children": ["bloom"] },
        "bloom": { "type": "Bloom", "props": { "intensity": 0.5, "luminanceThreshold": 0.8, "mipmapBlur": true }, "children": [] }
      }
    }
  },
