  "prompts": {
    "simple": "A login form with email and password",
    "medium": "A sales dashboard showing revenue metrics, a line chart of monthly sales, and a table of recent orders with status badges",
    "complex": "An admin panel with a sidebar navigation, a header with user profile and notifications, a main content area with a grid of metric cards (revenue, users, orders, conversion rate), a sales chart, a recent orders table with sorting and filtering, and action buttons for export and refresh",
    "3d_simple": "A floating sphere with studio lighting",
    "3d_product": "A product showroom with a metallic sphere on a reflective floor, studio lighting, bloom glow, and auto-rotating camera",
